# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.hypothesis/
htmlcov/
