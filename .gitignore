coverage.xml

# ── Node / Next.js ────────────────────────────────────────────────────────────
node_modules/
.next/
out/
.npm/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Secrets — NEVER commit .env, only .env.example ───────────────────────────
.env
# .env.example is intentionally NOT gitignored — it ships with empty values.

# ── IDE / editor ──────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*.swn
*.DS_Store
Thumbs.db

# ── OMC agent state (session-local, not project artifacts) ───────────────────
.omc/state/
**/.omc/state/
**/.omc/handoffs/
**/.omc/notes/
**/.omc/notepad.md
**/.omc/sessions/

