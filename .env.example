# Aglaea v0.1 — environment template
# Copy to .env, fill in values, then: chmod 600 .env
# NEVER commit .env — it is gitignored.
# Run scripts/bootstrap.sh to generate secrets automatically.

# ── Secrets (generate with: openssl rand -base64 32) ──────────────────────────
POSTGRES_PASSWORD=
DEEPSEEK_API_KEY=
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
SESSION_SECRET=
OTEL_SHARED_TOKEN=

# ── Configuration ──────────────────────────────────────────────────────────────
# GitHub login that gets auto-inserted into admin_users on first OAuth login.
BOOTSTRAP_GITHUB_LOGIN=lushuyu

# healthchecks.io ping URL — leave empty to disable the self-ping worker.
HEALTHCHECKS_SELFPING_URL=
